---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Blog — ${SITE_TITLE}`}
      description="Writing on AI, machine learning, and healthcare."
    />
    <style>
      /* ---------------------------------------------------------
       * ANIMATION STORYBOARD
       *
       * 0ms   list item enters from 0.4rem below
       * 0-240ms item fades and settles into place
       * 45ms  stagger between consecutive rows
       * max  first 10 rows receive stagger delay
       * --------------------------------------------------------- */
      main {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 2rem var(--space-page);
      }
      ul {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      li {
        padding: 1.25rem 0;
        content-visibility: auto;
        contain-intrinsic-size: 7rem;
        opacity: 0;
        transform: translateY(var(--motion-distance-sm));
        animation: blog-list-item-enter var(--motion-base)
          var(--ease-emphasized) both;
        animation-delay: calc(var(--stagger, 0) * var(--motion-stagger-step));
      }
      li + li {
        border-top: 1px solid var(--color-border);
      }
      li a {
        text-decoration: none;
        display: block;
      }
      .title {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--color-text);
        margin: 0 0 0.25rem;
        line-height: 1.3;
        overflow-wrap: anywhere;
        transition: color var(--motion-fast) var(--ease-standard);
      }
      li a:hover .title,
      li a:focus-visible .title {
        color: var(--color-accent);
      }
      .meta {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .date {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        white-space: nowrap;
      }
      .description {
        font-size: 0.9375rem;
        color: var(--color-text-muted);
        margin: 0.25rem 0 0;
        line-height: 1.5;
        overflow-wrap: anywhere;
      }
      .empty {
        color: var(--color-text-muted);
        font-size: 0.9375rem;
        padding: 2rem 0;
      }
      @keyframes blog-list-item-enter {
        from {
          opacity: 0;
          transform: translateY(var(--motion-distance-sm));
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        li {
          opacity: 1;
          transform: none;
          animation: none;
        }
        .title {
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main id="main-content">
      <h1 class="sr-only">Blog</h1>
      {
        posts.length === 0 ? (
          <p class="empty">No posts yet.</p>
        ) : (
          <ul>
            {posts.map((post, index) => (
              <li style={`--stagger: ${Math.min(index, 9)};`}>
                <a href={`/blog/${post.id}/`}>
                  <h2 class="title">{post.data.title}</h2>
                  <div class="meta">
                    <span class="date">
                      <FormattedDate date={post.data.pubDate} />
                    </span>
                  </div>
                  {post.data.description && (
                    <p class="description">{post.data.description}</p>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </main>
    <Footer />
  </body>
</html>
