---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`404 — ${SITE_TITLE}`}
      description="The page you are looking for could not be found."
    />
    <meta name="robots" content="noindex" />
    <style>
      /* ---------------------------------------------------------
       * ANIMATION STORYBOARD
       *
       * 0ms   eyebrow appears
       * 120ms title appears
       * 240ms message appears
       * --------------------------------------------------------- */
      main {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 0 var(--space-page);
        padding-top: 22vh;
      }
      @supports (height: 1dvh) {
        main {
          padding-top: 22dvh;
        }
      }
      .content {
        max-width: 560px;
        text-align: center;
      }
      .eyebrow {
        margin: 0 0 0.75rem;
        font-size: 0.75rem;
        color: var(--color-text-muted);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0;
        transform: translateY(var(--motion-distance-sm));
        animation: not-found-enter var(--motion-base) var(--ease-emphasized)
          both;
        animation-delay: 0ms;
      }
      h1 {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 500;
        margin: 0 0 0.5rem;
        line-height: 1.1;
        color: var(--color-text);
        opacity: 0;
        transform: translateY(var(--motion-distance-sm));
        animation: not-found-enter var(--motion-base) var(--ease-emphasized)
          both;
        animation-delay: 120ms;
      }
      .message {
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
        opacity: 0;
        transform: translateY(var(--motion-distance-sm));
        animation: not-found-enter var(--motion-base) var(--ease-emphasized)
          both;
        animation-delay: 240ms;
      }
      @keyframes not-found-enter {
        from {
          opacity: 0;
          transform: translateY(var(--motion-distance-sm));
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .eyebrow,
        h1,
        .message {
          opacity: 1;
          transform: none;
          animation: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main id="main-content">
      <section class="content" aria-labelledby="not-found-title">
        <p class="eyebrow">404</p>
        <h1 id="not-found-title">Page Not Found</h1>
        <p class="message">
          The page may have moved or the URL may be incorrect. Use the
          navigation above to continue browsing.
        </p>
      </section>
    </main>
  </body>
</html>
