---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body {
        margin: 0;
      }
      .blog-link {
        position: absolute;
        top: 1.5rem;
        right: var(--space-page);
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: var(--color-text-muted);
        text-decoration: none;
        min-width: 44px;
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .blog-link:hover {
        color: var(--color-text);
      }
      main {
        min-height: 100dvh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 0 var(--space-page);
        /* Golden ratio: top of content at ~38% from top */
        padding-top: 34vh;
      }
      @supports (height: 1dvh) {
        main {
          padding-top: 34dvh;
        }
      }
      .content {
        max-width: 560px;
        text-align: center;
      }
      h1 {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 500;
        margin: 0 0 0.5rem;
        line-height: 1.1;
        color: var(--color-text);
      }
      .tagline {
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0 0 1.5rem;
      }
      .links {
        font-size: 0.9375rem;
        color: var(--color-text-muted);
      }
      .links a {
        color: var(--color-text);
        text-decoration: none;
      }
      .links a:hover {
        color: var(--color-accent);
      }
      .sep {
        margin: 0 0.5em;
        color: var(--color-text-muted);
        user-select: none;
      }
    </style>
  </head>
  <body>
    <a href="/blog" class="blog-link">Blog</a>
    <main>
      <div class="content">
        <h1>Sumanth Ratna</h1>
        <p class="tagline">I work on AI and machine learning for healthcare.</p>
        <div class="links">
          <a href="https://github.com/sumanthratna/">GitHub</a>
          <span class="sep">&middot;</span>
          <a href="https://www.linkedin.com/in/sumanthratna/">LinkedIn</a>
          <span class="sep">&middot;</span>
          <a href="https://scholar.google.com/citations?user=XW5zExUAAAAJ"
            >Google Scholar</a
          >
        </div>
      </div>
    </main>
  </body>
</html>
