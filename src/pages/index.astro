---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 0 var(--space-page);
        padding-top: 24vh;
      }
      @supports (height: 1dvh) {
        main {
          padding-top: 24dvh;
        }
      }
      .content {
        max-width: 560px;
        text-align: center;
      }
      h1 {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 500;
        margin: 0 0 0.5rem;
        line-height: 1.1;
        color: var(--color-text);
      }
      .tagline {
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0 0 1.5rem;
      }
      .links {
        font-size: 0.9375rem;
        color: var(--color-text-muted);
      }
      .links a {
        color: var(--color-text);
      }
      .links a:hover {
        color: var(--color-accent);
      }
      .sep {
        margin: 0 0.5em;
        color: var(--color-text-muted);
        user-select: none;
      }
    </style>
  </head>
  <body>
    <Header />
    <main id="main-content">
      <div class="content">
        <h1>Sumanth Ratna</h1>
        <p class="tagline">I work on AI and machine learning for healthcare.</p>
        <div class="links">
          <a href="https://github.com/sumanthratna/">GitHub</a>
          <span class="sep">&middot;</span>
          <a href="https://www.linkedin.com/in/sumanthratna/">LinkedIn</a>
          <span class="sep">&middot;</span>
          <a href="https://scholar.google.com/citations?user=XW5zExUAAAAJ"
            >Google Scholar</a
          >
        </div>
      </div>
    </main>
  </body>
</html>
