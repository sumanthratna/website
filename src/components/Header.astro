---
const isHomePage = Astro.url.pathname === "/";
const isBlogPage = Astro.url.pathname.startsWith("/blog");
---

<a href="#main-content" class="skip-link">Skip to content</a>
<header>
  <nav>
    <a
      href="/"
      class="nav-link nav-link--start"
      aria-current={isHomePage ? "page" : undefined}
    >
      <span class="nav-label">Home</span>
    </a>
    <a
      href="/blog"
      class="nav-link nav-link--end"
      aria-current={isBlogPage ? "page" : undefined}
    >
      <span class="nav-label">Blog</span>
    </a>
  </nav>
</header>
<style>
  /* ---------------------------------------------------------
   * ANIMATION STORYBOARD
   *
   * 0ms   hover/focus starts
   * 160ms link color settles muted -> accent
   * 240ms underline scales from edge -> full width
   * page  active route keeps underline visible
   * --------------------------------------------------------- */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #fff;
    z-index: 100;
    font-size: 0.875rem;
  }
  .skip-link:focus-visible {
    left: 0;
  }
  header {
    padding: 1.5rem 0;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-page);
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    min-width: 44px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color var(--motion-fast) var(--ease-standard);
  }
  .nav-label {
    display: inline-block;
    position: relative;
    line-height: 1;
  }
  .nav-label::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.24em;
    height: 1px;
    background: var(--color-accent);
    opacity: 0.9;
    transform: scaleX(0);
    transform-origin: var(--underline-origin, left) center;
    transition: transform var(--motion-base) var(--ease-emphasized);
  }
  .nav-link--start {
    justify-content: flex-start;
    --underline-origin: left;
  }
  .nav-link--end {
    justify-content: flex-end;
    --underline-origin: right;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-accent);
  }
  .nav-link:hover .nav-label::after,
  .nav-link:focus-visible .nav-label::after {
    transform: scaleX(1);
  }
  .nav-link[aria-current="page"] {
    color: var(--color-text);
  }
  .nav-link[aria-current="page"] .nav-label::after {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-link {
      transition: none;
    }
    .nav-label::after {
      transition: none;
    }
  }
</style>
